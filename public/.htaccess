Options -MultiViews
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.html [QSA,L]

# إيقاف LiteSpeed cache بالكامل لهذا الموقع
<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>

# منع كاش index.html و sw.js — يجبر المتصفح على تحميل أحدث نسخة دائماً
<FilesMatch "^(index\.html|sw\.js|manifest\.json)$">
  Header always set Cache-Control "no-cache, no-store, must-revalidate"
  Header always set Pragma "no-cache"
  Header always set Expires "0"
</FilesMatch>

# السماح بكاش طويل للملفات ذات hash في الاسم (assets)
<FilesMatch "assets/.*\.(js|css)$">
  Header always set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
